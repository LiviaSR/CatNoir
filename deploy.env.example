# Copy to deploy.env and fill in your server details:
#   cp deploy.env.example deploy.env
#
# deploy.env is gitignored — never commit credentials or hostnames.

# SSH target (user@host or user@host -p port via ~/.ssh/config)
DEPLOY_SSH="user@your-server.example.org"

# Path to the git clone on the server
DEPLOY_REMOTE_REPO="/home/user/CatNoir"

# Web document root (what Apache/Nginx serves).
# Use a dedicated directory — do NOT point this at the repo root unless you
# know what you're doing (rsync --delete would remove source files).
DEPLOY_TARGET="/var/www/html/catnoir"

# Set to 1 to run `git pull` on the server before building
DEPLOY_GIT_PULL=1
